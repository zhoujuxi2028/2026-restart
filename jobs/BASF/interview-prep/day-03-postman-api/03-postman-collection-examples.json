{
	"info": {
		"_postman_id": "basf-interview-api-tests",
		"name": "BASF Interview - JSONPlaceholder API Tests",
		"description": "Comprehensive API test collection demonstrating Postman best practices for BASF QA Automation Engineer interview.\n\nFeatures:\n- Complete CRUD operations\n- Authentication flow examples\n- Schema validation\n- Error scenario testing\n- Data-driven test examples\n- Performance assertions\n\nBase API: https://jsonplaceholder.typicode.com",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{bearerToken}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Collection-level Pre-request Script",
					"// Runs before every request in this collection",
					"",
					"// Set timestamp for dynamic data",
					"pm.environment.set('timestamp', new Date().toISOString());",
					"",
					"// Add default headers",
					"pm.request.headers.add({",
					"    key: 'X-Client-Version',",
					"    value: '1.0.0'",
					"});",
					"",
					"// Generate random test data",
					"const randomId = Math.floor(Math.random() * 1000);",
					"pm.environment.set('randomUserId', randomId);",
					"",
					"console.log(`[${pm.info.requestName}] Starting request at ${pm.environment.get('timestamp')}`);"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Collection-level Test Script",
					"// Runs after every request in this collection",
					"",
					"// Performance baseline test",
					"pm.test('Response time is acceptable', function () {",
					"    pm.expect(pm.response.responseTime).to.be.below(5000);",
					"});",
					"",
					"// Content-Type validation (except for 204 No Content)",
					"if (pm.response.code !== 204) {",
					"    pm.test('Content-Type is application/json', function () {",
					"        pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
					"    });",
					"}",
					"",
					"// Log response summary",
					"console.log(`[${pm.info.requestName}] Status: ${pm.response.code}, Time: ${pm.response.responseTime}ms`);"
				]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "https://jsonplaceholder.typicode.com",
			"type": "string"
		},
		{
			"key": "apiVersion",
			"value": "v1",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "01-Setup",
			"description": "Initial setup and health check requests",
			"item": [
				{
					"name": "Health Check",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('API is reachable', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response is an array', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"});",
									"",
									"pm.test('API returns data', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.length).to.be.above(0);",
									"    console.log(`API returned ${jsonData.length} items`);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/posts",
							"host": ["{{baseUrl}}"],
							"path": ["posts"]
						},
						"description": "Verify API is accessible and returning data"
					}
				}
			]
		},
		{
			"name": "02-Users-CRUD",
			"description": "Complete CRUD operations for User resources",
			"item": [
				{
					"name": "GET All Users",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response is an array', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"    pm.expect(jsonData.length).to.be.above(0);",
									"});",
									"",
									"pm.test('Each user has required fields', function () {",
									"    const jsonData = pm.response.json();",
									"    jsonData.forEach(user => {",
									"        pm.expect(user).to.have.property('id');",
									"        pm.expect(user).to.have.property('name');",
									"        pm.expect(user).to.have.property('email');",
									"        pm.expect(user).to.have.property('username');",
									"    });",
									"});",
									"",
									"// Save first user ID for subsequent tests",
									"const users = pm.response.json();",
									"if (users.length > 0) {",
									"    pm.environment.set('testUserId', users[0].id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users",
							"host": ["{{baseUrl}}"],
							"path": ["users"]
						}
					}
				},
				{
					"name": "GET Single User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response is an object', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('object');",
									"});",
									"",
									"// JSON Schema Validation",
									"const schema = {",
									"    type: 'object',",
									"    required: ['id', 'name', 'email', 'username'],",
									"    properties: {",
									"        id: { type: 'integer', minimum: 1 },",
									"        name: { type: 'string', minLength: 1 },",
									"        email: { type: 'string', format: 'email' },",
									"        username: { type: 'string', minLength: 1 },",
									"        address: { type: 'object' },",
									"        company: { type: 'object' }",
									"    }",
									"};",
									"",
									"pm.test('Response matches user schema', function () {",
									"    pm.response.to.have.jsonSchema(schema);",
									"});",
									"",
									"pm.test('User ID matches request', function () {",
									"    const jsonData = pm.response.json();",
									"    const requestedId = parseInt(pm.environment.get('testUserId'));",
									"    pm.expect(jsonData.id).to.equal(requestedId);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/{{testUserId}}",
							"host": ["{{baseUrl}}"],
							"path": ["users", "{{testUserId}}"]
						}
					}
				},
				{
					"name": "POST Create User",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Generate dynamic test data",
									"const timestamp = Date.now();",
									"pm.environment.set('testUsername', `testuser_${timestamp}`);",
									"pm.environment.set('testEmail', `test${timestamp}@example.com`);"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Response contains created user', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.expect(jsonData.name).to.equal(pm.environment.get('testUsername'));",
									"    pm.expect(jsonData.email).to.equal(pm.environment.get('testEmail'));",
									"});",
									"",
									"// Save created ID for cleanup",
									"const createdId = pm.response.json().id;",
									"pm.environment.set('createdUserId', createdId);",
									"console.log(`Created user with ID: ${createdId}`);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"{{testUsername}}\",\n    \"email\": \"{{testEmail}}\",\n    \"username\": \"{{testUsername}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/users",
							"host": ["{{baseUrl}}"],
							"path": ["users"]
						}
					}
				},
				{
					"name": "PUT Update User (Full)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('User data updated correctly', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.name).to.equal('Updated User Name');",
									"    pm.expect(jsonData.email).to.equal('updated@example.com');",
									"});",
									"",
									"pm.test('PUT is idempotent', function () {",
									"    // Running same PUT multiple times should produce same result",
									"    pm.expect(pm.response.code).to.equal(200);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"id\": {{testUserId}},\n    \"name\": \"Updated User Name\",\n    \"email\": \"updated@example.com\",\n    \"username\": \"updated_username\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/users/{{testUserId}}",
							"host": ["{{baseUrl}}"],
							"path": ["users", "{{testUserId}}"]
						}
					}
				},
				{
					"name": "PATCH Update User (Partial)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Only specified field is updated', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.email).to.equal('patched@example.com');",
									"    // Other fields should remain unchanged (in real API)",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"patched@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/users/{{testUserId}}",
							"host": ["{{baseUrl}}"],
							"path": ["users", "{{testUserId}}"]
						}
					}
				},
				{
					"name": "DELETE User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('DELETE is idempotent', function () {",
									"    // Deleting same resource multiple times should succeed",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
									"});",
									"",
									"console.log(`Deleted user ID: ${pm.environment.get('testUserId')}`);"
								]
							}
						}
					],
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/{{testUserId}}",
							"host": ["{{baseUrl}}"],
							"path": ["users", "{{testUserId}}"]
						}
					}
				}
			]
		},
		{
			"name": "03-Posts-API",
			"description": "Testing posts resources and relationships",
			"item": [
				{
					"name": "GET All Posts",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Returns array of posts', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"    pm.expect(jsonData.length).to.be.above(0);",
									"});",
									"",
									"// Performance test",
									"pm.test('Response time < 500ms', function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(500);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/posts",
							"host": ["{{baseUrl}}"],
							"path": ["posts"]
						}
					}
				},
				{
					"name": "GET Posts by User (Query Params)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('All posts belong to specified user', function () {",
									"    const jsonData = pm.response.json();",
									"    const userId = parseInt(pm.environment.get('testUserId'));",
									"    ",
									"    jsonData.forEach(post => {",
									"        pm.expect(post.userId).to.equal(userId);",
									"    });",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/posts?userId={{testUserId}}",
							"host": ["{{baseUrl}}"],
							"path": ["posts"],
							"query": [
								{
									"key": "userId",
									"value": "{{testUserId}}"
								}
							]
						}
					}
				},
				{
					"name": "GET Post Comments (Nested Resource)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Returns array of comments', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"});",
									"",
									"pm.test('Each comment has required structure', function () {",
									"    const jsonData = pm.response.json();",
									"    jsonData.forEach(comment => {",
									"        pm.expect(comment).to.have.all.keys('postId', 'id', 'name', 'email', 'body');",
									"    });",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/posts/1/comments",
							"host": ["{{baseUrl}}"],
							"path": ["posts", "1", "comments"]
						}
					}
				}
			]
		},
		{
			"name": "04-Error-Scenarios",
			"description": "Testing various error conditions",
			"item": [
				{
					"name": "404 - Non-existent Resource",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 404', function () {",
									"    pm.response.to.have.status(404);",
									"});",
									"",
									"pm.test('Error response structure', function () {",
									"    // JSONPlaceholder returns empty object for 404",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('object');",
									"});",
									"",
									"console.log('404 error handled correctly');"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/99999",
							"host": ["{{baseUrl}}"],
							"path": ["users", "99999"]
						}
					}
				},
				{
					"name": "400 - Invalid POST Data",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Note: JSONPlaceholder is lenient and may still return 201",
									"// In a real API, this should return 400",
									"pm.test('Request processed', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([400, 201]);",
									"});",
									"",
									"if (pm.response.code === 400) {",
									"    pm.test('Error message provided', function () {",
									"        const jsonData = pm.response.json();",
									"        pm.expect(jsonData).to.have.property('message');",
									"    });",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"\",\n    \"email\": \"invalid-email\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/users",
							"host": ["{{baseUrl}}"],
							"path": ["users"]
						}
					}
				}
			]
		},
		{
			"name": "05-Performance-Tests",
			"description": "Performance and load testing scenarios",
			"item": [
				{
					"name": "Performance Baseline - Fast Endpoint",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Strict performance requirement",
									"pm.test('Response time < 300ms', function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(300);",
									"});",
									"",
									"// Log for trend analysis",
									"var currentResponseTime = pm.response.responseTime;",
									"console.log(`Performance: ${currentResponseTime}ms`);",
									"",
									"// Store baseline",
									"if (!pm.environment.get('baselineTime')) {",
									"    pm.environment.set('baselineTime', currentResponseTime);",
									"    console.log(`Baseline set: ${currentResponseTime}ms`);",
									"} else {",
									"    var baseline = pm.environment.get('baselineTime');",
									"    var degradation = ((currentResponseTime - baseline) / baseline) * 100;",
									"    console.log(`Performance vs baseline: ${degradation.toFixed(2)}%`);",
									"    ",
									"    if (degradation > 50) {",
									"        console.warn('⚠️ Performance degradation detected!');",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/1",
							"host": ["{{baseUrl}}"],
							"path": ["users", "1"]
						}
					}
				}
			]
		}
	]
}
