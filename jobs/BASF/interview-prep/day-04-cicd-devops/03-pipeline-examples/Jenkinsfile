// Jenkins Declarative Pipeline
// This file demonstrates a complete CI/CD pipeline for running Cypress and Newman tests
// in Jenkins with parallel execution, Docker agents, and comprehensive error handling.
//
// Interview Talking Point:
// "This Jenkinsfile showcases Jenkins' power and flexibility. It uses declarative
// pipeline syntax for readability while leveraging Jenkins' extensive plugin ecosystem.
// Jenkins is ideal for complex enterprise workflows with custom requirements."

// Pipeline definition
pipeline {
    // Agent configuration - where pipeline runs
    // Interview Talking Point:
    // "We use 'agent any' at the top level, then specify Docker images for each stage.
    // This gives us clean, isolated environments for each stage while utilizing
    // Jenkins' Docker integration."
    agent any

    // Pipeline parameters (can be set when triggering manually)
    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['staging', 'production'],
            description: 'Target deployment environment'
        )
        booleanParam(
            name: 'SKIP_TESTS',
            defaultValue: false,
            description: 'Skip test execution (use with caution!)'
        )
        string(
            name: 'BROWSER',
            defaultValue: 'chrome',
            description: 'Browser for E2E tests'
        )
    }

    // Environment variables accessible throughout pipeline
    environment {
        // Node and npm configuration
        NODE_VERSION = '16'
        npm_config_cache = "${WORKSPACE}/.npm"

        // Cypress configuration
        CYPRESS_CACHE_FOLDER = "${WORKSPACE}/.cache/Cypress"
        CYPRESS_BASE_URL = 'https://staging.example.com'

        // Docker configuration
        DOCKER_REGISTRY = 'docker.io'

        // Credentials (loaded from Jenkins credentials store)
        CYPRESS_RECORD_KEY = credentials('cypress-record-key')
        API_KEY = credentials('api-key')
        SLACK_WEBHOOK = credentials('slack-webhook-url')
    }

    // Build options
    options {
        // Keep last 30 builds
        buildDiscarder(logRotator(numToKeepStr: '30'))

        // Timeout entire pipeline after 60 minutes
        timeout(time: 60, unit: 'MINUTES')

        // Add timestamps to console output
        timestamps()

        // Don't allow concurrent builds of same branch
        disableConcurrentBuilds()

        // Colorize console output
        ansiColor('xterm')
    }

    // Pipeline stages
    stages {
        // Stage 1: Checkout and Setup
        // Interview Talking Point:
        // "The checkout stage retrieves source code and prepares the workspace.
        // Jenkins automatically handles Git operations including submodules and
        // LFS if needed."
        stage('Checkout') {
            agent any
            steps {
                echo '📥 Checking out source code...'

                // Checkout code from SCM
                checkout scm

                // Print build information
                script {
                    echo "Building branch: ${env.BRANCH_NAME}"
                    echo "Build number: ${env.BUILD_NUMBER}"
                    echo "Workspace: ${env.WORKSPACE}"
                }

                echo '✅ Checkout complete'
            }
        }

        // Stage 2: Install Dependencies
        // Interview Talking Point:
        // "We use a Node.js Docker image for consistent dependency installation.
        // Jenkins' Docker integration allows us to use any Docker image as an
        // agent, ensuring reproducible builds."
        stage('Install Dependencies') {
            agent {
                docker {
                    image 'node:16-alpine'
                    args '-v $HOME/.npm:/.npm -v $HOME/.cache/Cypress:/.cache/Cypress'
                    reuseNode true
                }
            }
            steps {
                echo '📦 Installing dependencies...'

                // Cache check
                sh '''
                    if [ -d "node_modules" ] && [ -f ".npm-cache-valid" ]; then
                        echo "Using cached dependencies"
                    else
                        echo "Installing fresh dependencies"
                        npm ci --cache .npm --prefer-offline
                        touch .npm-cache-valid
                    fi
                '''

                // Verify Cypress installation
                sh 'npx cypress verify'

                echo '✅ Dependencies installed'
            }
        }

        // Stage 3: Lint and Static Analysis
        // Interview Talking Point:
        // "Linting provides fast feedback on code quality. If lint fails, we
        // fail fast before running expensive tests. This saves time and compute
        // resources."
        stage('Lint') {
            agent {
                docker {
                    image 'node:16-alpine'
                    reuseNode true
                }
            }
            steps {
                echo '🔍 Running ESLint...'
                sh 'npm run lint'
                echo '✅ Lint checks passed'
            }
        }

        // Stage 4: Unit Tests
        // Interview Talking Point:
        // "Unit tests run quickly and provide immediate feedback. We publish
        // JUnit results so Jenkins can track test trends over time and provide
        // rich test reporting in the UI."
        stage('Unit Tests') {
            agent {
                docker {
                    image 'node:16-alpine'
                    reuseNode true
                }
            }
            steps {
                echo '🧪 Running unit tests...'
                sh 'npm run test:unit -- --coverage --reporters=default --reporters=jest-junit'
                echo '✅ Unit tests passed'
            }
            post {
                always {
                    // Publish JUnit test results
                    junit 'junit.xml'

                    // Publish code coverage
                    publishHTML(target: [
                        reportDir: 'coverage',
                        reportFiles: 'index.html',
                        reportName: 'Code Coverage Report'
                    ])

                    // Archive coverage data
                    archiveArtifacts artifacts: 'coverage/**/*', allowEmptyArchive: true
                }
            }
        }

        // Stage 5: Build Application
        // Interview Talking Point:
        // "The build stage compiles the application and creates artifacts. If
        // the build fails, there's no point running tests. This stage acts as
        // a quality gate."
        stage('Build') {
            agent {
                docker {
                    image 'node:16-alpine'
                    reuseNode true
                }
            }
            when {
                // Only build on main and develop branches
                anyOf {
                    branch 'main'
                    branch 'develop'
                }
            }
            steps {
                echo '🏗️ Building application...'
                sh 'npm run build'
                echo '✅ Build complete'
            }
            post {
                success {
                    // Archive build artifacts
                    archiveArtifacts artifacts: 'dist/**/*', allowEmptyArchive: false
                }
            }
        }

        // Stage 6: Parallel Testing
        // Interview Talking Point:
        // "This is where Jenkins' parallel execution shines. We run Cypress E2E
        // tests and Newman API tests simultaneously on different agents. This
        // parallel execution reduces our test time by 50%."
        stage('Parallel Testing') {
            when {
                expression { return !params.SKIP_TESTS }
            }
            parallel {
                // Parallel branch 1: Cypress E2E Tests
                stage('Cypress E2E Tests') {
                    agent {
                        docker {
                            image 'cypress/browsers:node16.14.2-chrome100-ff99'
                            args '-v /dev/shm:/dev/shm'  // Shared memory for Chrome
                            reuseNode true
                        }
                    }
                    steps {
                        echo "🚀 Starting Cypress tests on ${params.BROWSER}..."

                        // Wait for application (if needed)
                        script {
                            if (env.CYPRESS_BASE_URL) {
                                sh """
                                    echo "⏳ Waiting for application at ${CYPRESS_BASE_URL}..."
                                    timeout 60 bash -c 'until curl -f ${CYPRESS_BASE_URL}/health; do sleep 2; done' || true
                                """
                            }
                        }

                        // Run Cypress tests
                        sh """
                            npx cypress run \
                                --browser ${params.BROWSER} \
                                --headless \
                                --record \
                                --parallel \
                                --ci-build-id ${env.BUILD_TAG} \
                                --group "E2E Tests - Jenkins" \
                                --config video=true,screenshotOnRunFailure=true
                        """

                        echo '✅ Cypress tests passed'
                    }
                    post {
                        always {
                            // Archive Cypress artifacts
                            archiveArtifacts artifacts: 'cypress/screenshots/**/*', allowEmptyArchive: true
                            archiveArtifacts artifacts: 'cypress/videos/**/*', allowEmptyArchive: true

                            // Publish test results
                            junit 'cypress/results/*.xml'
                        }
                        failure {
                            echo '❌ Cypress tests failed'
                        }
                    }
                }

                // Parallel branch 2: Newman API Tests
                stage('Newman API Tests') {
                    agent {
                        docker {
                            image 'postman/newman:alpine'
                            reuseNode true
                        }
                    }
                    steps {
                        echo '🔧 Running Newman API tests...'

                        // Run Newman for each collection
                        script {
                            def collections = ['auth-api', 'users-api', 'products-api', 'orders-api']

                            collections.each { collection ->
                                echo "Testing ${collection}..."
                                sh """
                                    newman run \
                                        postman/collections/${collection}.json \
                                        --environment postman/environments/staging.json \
                                        --reporters cli,htmlextra,junit \
                                        --reporter-htmlextra-export newman-reports/${collection}-report.html \
                                        --reporter-junit-export newman-reports/${collection}-junit.xml \
                                        --bail \
                                        --delay-request 500 \
                                        --timeout-request 10000
                                """
                            }
                        }

                        echo '✅ API tests passed'
                    }
                    post {
                        always {
                            // Archive Newman reports
                            archiveArtifacts artifacts: 'newman-reports/**/*', allowEmptyArchive: true

                            // Publish test results
                            junit 'newman-reports/*-junit.xml'

                            // Publish HTML reports
                            publishHTML(target: [
                                reportDir: 'newman-reports',
                                reportFiles: '*-report.html',
                                reportName: 'Newman API Test Reports'
                            ])
                        }
                    }
                }

                // Parallel branch 3: Performance Tests (optional)
                stage('Performance Tests') {
                    when {
                        anyOf {
                            branch 'main'
                            branch 'develop'
                        }
                    }
                    agent {
                        docker {
                            image 'justb4/jmeter:latest'
                            reuseNode true
                        }
                    }
                    steps {
                        echo '⚡ Running performance tests...'

                        sh '''
                            jmeter -n \
                                -t performance-tests/load-test.jmx \
                                -l performance-tests/results.jtl \
                                -e -o performance-tests/report
                        '''

                        echo '✅ Performance tests complete'
                    }
                    post {
                        always {
                            archiveArtifacts artifacts: 'performance-tests/report/**/*'
                            publishHTML(target: [
                                reportDir: 'performance-tests/report',
                                reportFiles: 'index.html',
                                reportName: 'Performance Test Report'
                            ])
                        }
                    }
                }
            }
        }

        // Stage 7: Security Scanning
        // Interview Talking Point:
        // "Security scanning is integrated into our pipeline. We scan for known
        // vulnerabilities in dependencies and fail the build if critical issues
        // are found. This enforces security best practices."
        stage('Security Scan') {
            agent {
                docker {
                    image 'node:16-alpine'
                    reuseNode true
                }
            }
            steps {
                echo '🔒 Running security scan...'

                // npm audit
                sh 'npm audit --audit-level=high || true'

                // Snyk scan (if available)
                script {
                    try {
                        sh 'snyk test --severity-threshold=high'
                    } catch (Exception e) {
                        echo 'Snyk not configured, skipping...'
                    }
                }

                echo '✅ Security scan complete'
            }
        }

        // Stage 8: Deploy to Staging
        // Interview Talking Point:
        // "Deployment only happens if all tests pass. We use Blue-Green deployment
        // strategy to enable instant rollback if issues are detected post-deployment."
        stage('Deploy to Staging') {
            when {
                allOf {
                    branch 'main'
                    expression { return params.ENVIRONMENT == 'staging' }
                }
            }
            agent any
            steps {
                echo '🚀 Deploying to staging environment...'

                script {
                    // Deployment logic here (e.g., kubectl, AWS CLI, etc.)
                    sh '''
                        echo "Deployment would happen here"
                        # Example: kubectl apply -f k8s/staging/
                        # Example: aws s3 sync dist/ s3://staging-bucket/
                    '''

                    // Health check
                    echo '⏳ Waiting for staging deployment to be ready...'
                    sh '''
                        timeout 120 bash -c 'until curl -f https://staging.example.com/health; do sleep 5; done'
                    '''
                }

                echo '✅ Staging deployment successful'
            }
            post {
                success {
                    // Send notification
                    slackSend(
                        color: 'good',
                        message: "Staging deployment successful: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                        channel: '#deployments'
                    )
                }
                failure {
                    slackSend(
                        color: 'danger',
                        message: "Staging deployment failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                        channel: '#deployments'
                    )
                }
            }
        }

        // Stage 9: Deploy to Production (Manual Approval)
        // Interview Talking Point:
        // "Production deployment requires manual approval. Jenkins pauses here
        // and waits for an authorized person to review and approve. This is a
        // critical quality gate before production changes."
        stage('Deploy to Production') {
            when {
                allOf {
                    branch 'main'
                    expression { return params.ENVIRONMENT == 'production' }
                }
            }
            agent any
            steps {
                // Manual approval step
                // Interview Talking Point:
                // "The input step pauses the pipeline and requires human approval.
                // We can restrict who can approve using Jenkins' role-based access
                // control."
                script {
                    def userInput = input(
                        id: 'ProductionDeployment',
                        message: 'Deploy to Production?',
                        parameters: [
                            booleanParam(
                                defaultValue: false,
                                description: 'Confirm production deployment',
                                name: 'CONFIRM_DEPLOYMENT'
                            )
                        ],
                        submitter: 'admin,release-manager'  // Only these roles can approve
                    )

                    if (!userInput) {
                        error('Production deployment cancelled')
                    }
                }

                echo '🚀 Deploying to production environment...'

                script {
                    // Production deployment logic
                    sh '''
                        echo "Production deployment would happen here"
                        # Example: kubectl apply -f k8s/production/
                    '''

                    // Health check
                    echo '⏳ Verifying production deployment...'
                    sh '''
                        timeout 120 bash -c 'until curl -f https://example.com/health; do sleep 5; done'
                    '''
                }

                echo '✅ Production deployment successful'
            }
            post {
                success {
                    // Tag release
                    sh """
                        git tag -a v${env.BUILD_NUMBER} -m "Production release ${env.BUILD_NUMBER}"
                        git push origin v${env.BUILD_NUMBER}
                    """

                    // Send notification
                    slackSend(
                        color: 'good',
                        message: "🎉 Production deployment successful: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                        channel: '#deployments'
                    )

                    // Send email to stakeholders
                    emailext(
                        subject: "Production Release ${env.BUILD_NUMBER}",
                        body: """
                            Production deployment completed successfully.

                            Build: ${env.BUILD_URL}
                            Version: v${env.BUILD_NUMBER}
                            Branch: ${env.BRANCH_NAME}
                            Commit: ${env.GIT_COMMIT}
                        """,
                        to: 'team@example.com'
                    )
                }
                failure {
                    slackSend(
                        color: 'danger',
                        message: "❌ Production deployment failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                        channel: '#deployments'
                    )

                    // Trigger rollback pipeline
                    build job: 'rollback-production', parameters: [
                        string(name: 'BUILD_TO_ROLLBACK', value: "${env.BUILD_NUMBER}")
                    ]
                }
            }
        }
    }

    // Post-pipeline actions
    // Interview Talking Point:
    // "Post actions run after the pipeline completes, regardless of success or
    // failure. This is where we clean up, send notifications, and update dashboards."
    post {
        always {
            // Clean workspace on successful builds (save disk space)
            cleanWs(
                deleteDirs: true,
                patterns: [
                    [pattern: 'node_modules', type: 'INCLUDE'],
                    [pattern: '.npm', type: 'INCLUDE'],
                    [pattern: '.cache', type: 'INCLUDE']
                ]
            )

            // Archive important build information
            script {
                def buildInfo = """
                    Build Number: ${env.BUILD_NUMBER}
                    Branch: ${env.BRANCH_NAME}
                    Commit: ${env.GIT_COMMIT}
                    Build URL: ${env.BUILD_URL}
                    Duration: ${currentBuild.durationString}
                """
                writeFile file: 'build-info.txt', text: buildInfo
                archiveArtifacts artifacts: 'build-info.txt'
            }
        }

        success {
            echo '✅ Pipeline completed successfully!'

            // Update build description
            script {
                currentBuild.description = "✅ All tests passed | Branch: ${env.BRANCH_NAME}"
            }

            // Send success notification
            slackSend(
                color: 'good',
                message: "Build successful: ${env.JOB_NAME} #${env.BUILD_NUMBER}\nBranch: ${env.BRANCH_NAME}\n${env.BUILD_URL}",
                channel: '#ci-cd'
            )
        }

        failure {
            echo '❌ Pipeline failed!'

            // Update build description
            script {
                currentBuild.description = "❌ Build failed | Branch: ${env.BRANCH_NAME}"
            }

            // Send failure notification with details
            slackSend(
                color: 'danger',
                message: """
                    Build failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}
                    Branch: ${env.BRANCH_NAME}
                    Failed Stage: ${env.STAGE_NAME}
                    ${env.BUILD_URL}console
                """,
                channel: '#ci-cd'
            )

            // Email responsible parties
            emailext(
                subject: "Build Failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                    Build failed at stage: ${env.STAGE_NAME}

                    Console Output: ${env.BUILD_URL}console
                    Branch: ${env.BRANCH_NAME}
                    Commit: ${env.GIT_COMMIT}

                    Please investigate and fix.
                """,
                to: '${DEFAULT_RECIPIENTS}',
                recipientProviders: [
                    [$class: 'CulpritsRecipientProvider'],
                    [$class: 'DevelopersRecipientProvider']
                ]
            )
        }

        unstable {
            echo '⚠️ Pipeline completed with warnings'
            slackSend(
                color: 'warning',
                message: "Build unstable: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                channel: '#ci-cd'
            )
        }

        aborted {
            echo '🛑 Pipeline was aborted'
            slackSend(
                color: 'warning',
                message: "Build aborted: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                channel: '#ci-cd'
            )
        }
    }
}

// Interview Tips for Discussing This Jenkinsfile:
//
// 1. Emphasize Flexibility:
//    "Jenkins offers the most flexibility. We can use any Docker image, integrate
//    with any tool, and implement complex conditional logic. This Jenkinsfile shows
//    parallel execution, manual approvals, and extensive post-build actions."
//
// 2. Highlight Plugin Ecosystem:
//    "Jenkins has 1800+ plugins. We use the Docker plugin for containerized builds,
//    the JUnit plugin for test reporting, the Slack plugin for notifications, and
//    many others. This ecosystem is Jenkins' biggest strength."
//
// 3. Discuss Groovy Scripting:
//    "Jenkins uses Groovy, which allows for powerful scripting. We can implement
//    complex logic, loops, conditional execution, and dynamic pipeline generation.
//    This is harder to achieve in YAML-based systems."
//
// 4. Explain Manual Approval:
//    "The input step for production deployment is a critical quality gate. Only
//    authorized users can approve, and the pipeline pauses until approval is given
//    or the timeout is reached."
//
// 5. Mention Notifications:
//    "We have comprehensive notification strategy: Slack for real-time alerts,
//    email for formal notifications, and build descriptions in Jenkins UI. The
//    post section ensures notifications happen regardless of where the pipeline fails."
//
// 6. Discuss Clean-up:
//    "Pipeline clean-up is important for disk space management. We clean workspace
//    after builds but preserve important artifacts and test results for debugging."
//
// 7. Talk About Enterprise Features:
//    "Jenkins offers enterprise features like role-based access control, pipeline
//    as code, multi-branch pipelines, and extensive audit logging. It's battle-tested
//    in large organizations with complex requirements."
