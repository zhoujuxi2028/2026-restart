# test:newman:
#   stage: test
#   image:
#     name: newman-tests:latest
#   script:
#     - run-all-tests
#   artifacts:
#     when: always
#     paths:
#       - reports/
#     reports:
#       junit: reports/*-junit.xml

# Example parallel execution in CI (GitHub Actions):
# strategy:
#   matrix:
#     collection: [auth-api, users-api, products-api, orders-api]
# steps:
#   - run: |
#       docker run --rm \
#         -v $(pwd)/reports:/etc/newman/reports \
#         -e API_KEY=${{ secrets.API_KEY }} \
#         newman-tests:latest \
#         newman run collections/${{ matrix.collection }}.json \
#         --environment environments/staging.json \
#         --reporters cli,htmlextra,junit
